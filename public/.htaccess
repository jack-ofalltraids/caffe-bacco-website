<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Behalte die index.html aus dem Rewrite raus
  RewriteRule ^index\.html$ - [L]
  
  # WICHTIG: Wenn die Datei physisch existiert (wie unsere news.json), NICHT umleiten!
  RewriteCond %{REQUEST_FILENAME} !-f
  # Wenn es ein Ordner ist, NICHT umleiten!
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Alles andere auf die React SPA (index.html) leiten
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Stelle sicher, dass die news.json IMMER frisch geladen wird und niemals beim Provider festhängt
  <Files "news.json">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </Files>
</IfModule>
