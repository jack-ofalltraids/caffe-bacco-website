# Caffe Bacco - Environment Variables
# Copy this file to .env and fill in your values

# n8n Webhook URL for reservation requests
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# Authorization token for the webhook (Header Auth in n8n)
VITE_N8N_WEBHOOK_TOKEN=Bearer your-secret-token
